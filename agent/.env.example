# Copy this to agent/.env and fill in your values
# agent/.env is gitignored — never commit it

# Shared secret — must match TERM_TOKEN on the OCI server
TERM_TOKEN=your-secret-token-here

# WebSocket relay URL (no trailing slash)
RELAY_URL=wss://chans.place

# Command to run inside the PTY (default: bash)
# TERM_CMD=bash
# TERM_CMD=claude

# Terminal size
# TERM_ROWS=24
# TERM_COLS=220
