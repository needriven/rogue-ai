# ── OCI / Deploy ─────────────────────────────────────
# Copy to .env and fill in (never commit .env)

# GitHub Container Registry image tag (set by CI/CD)
IMAGE_TAG=latest

# GitHub repository (owner/repo) — used for ghcr.io image name
GITHUB_REPOSITORY=needriven/rogue-ai

# SSL domain (leave empty to run HTTP-only)
DOMAIN=

# Certbot email (for Let's Encrypt notifications)
CERTBOT_EMAIL=
